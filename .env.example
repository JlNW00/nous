# ============================================================================
# Crypto Investigator — Environment Config (No Docker Required)
# ============================================================================
# Sign up for free tiers at each service, paste your connection strings below.

# === PostgreSQL (Neon.tech or Supabase — free tier) ===
# Neon: https://neon.tech  ->  Create project  ->  copy connection string
# Supabase: https://supabase.com  ->  New project  ->  Settings  ->  Database
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# === Redis (Upstash — free tier) ===
# https://upstash.com  ->  Create database  ->  copy Redis URL
REDIS_URL=rediss://default:password@host:port

# === Neo4j (Aura Free) ===
# https://neo4j.com/cloud/aura-free/  ->  Create instance  ->  copy credentials
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# === Provider API Keys ===
HELIUS_API_KEY=
DEXSCREENER_API_KEY=
ETHERSCAN_API_KEY=
SOLSCAN_API_KEY=
GITHUB_TOKEN=
X_BEARER_TOKEN=

# === LLM ===
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514

# === App ===
ENV=development
LOG_LEVEL=INFO
API_PORT=8000
CASE_MAX_DEPTH=5
CASE_BUDGET_LIMIT_USD=0.50
